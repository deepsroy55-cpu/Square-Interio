# Square Interio Local Email Server Configuration (SMTP)
# Rename this file to .env and fill in your email provider credentials to test email submissions locally on localhost:3000.

PORT=3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
